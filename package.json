{
  "name": "granja-el-rancho",
  "version": "1.0.0",
  "description": "PWA administrativa y operativa para la granja avicola El Rancho.",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "NODE_ENV=production tsx server/index.ts",
    "migrate": "tsx server/migrate.ts",
    "create-admin": "tsx server/create-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "idb": "^8.0.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.16",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4"
  }
}
