# En Vercel configura estas variables en Project Settings > Environment Variables:
#   DATABASE_URL  (cadena de Neon)
#   JWT_SECRET    (un secreto largo y aleatorio, NO el de ejemplo)
# APP_ORIGIN y PORT solo aplican para desarrollo local.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
JWT_SECRET=change-this-secret
APP_ORIGIN=http://localhost:5173
PORT=8787

# Usado por npm run create-admin
ADMIN_EMAIL=dadafafa538@gmail.com
ADMIN_PASSWORD=123456
ADMIN_NAME=Administrador El Rancho
